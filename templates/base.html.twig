<!DOCTYPE html>
{# /templates/base.html.twig #}
<html lang="fr">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{% block title %}Le garage d'un Geek{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>">
        
        {% block stylesheets %}
            {{ importmap('app') }}
        {% endblock %}
    </head>
    <body>
        {% include '_partials/_header.html.twig' %}

        <main class="container">
            {% block body %}{% endblock %}
        </main>

        {% include '_partials/_footer.html.twig' %}

        {% block javascripts %}
            <script src="https://cdnjs.cloudflare.com/ajax/libs/fslightbox/3.0.9/index.js"></script>
            
            <script>
                function initializeLightbox() {
                    const images = document.querySelectorAll('.about-text-body img, .post-full-content img, .post-content img');
                    
                    images.forEach(img => {
                        if (img.parentElement.tagName === 'A') return;

                        const link = document.createElement('a');
                        link.setAttribute('data-fslightbox', 'gallery');
                        link.setAttribute('href', img.src);
                        
                        // ON RETIRE LE .style.cursor ICI
                        // On ajoute une classe à la place
                        link.classList.add('ui-lightbox-trigger');

                        img.parentNode.insertBefore(link, img);
                        link.appendChild(img);
                    });

                    if (window.refreshFsLightbox) {
                        refreshFsLightbox();
                    }
                }

                document.addEventListener("DOMContentLoaded", initializeLightbox);
                document.addEventListener("turbo:load", initializeLightbox);
            </script>
        {% endblock %}
    </body>
</html>
