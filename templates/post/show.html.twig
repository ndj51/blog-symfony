{# /templates/post/show.html.twig #}
{% extends 'base.html.twig' %}

{% block javascripts %}
    {{ parent() }}
    <script src="{{ asset('js/share.js') }}"></script>
{% endblock %}

{% block title %}{{ post.title }}{% endblock %}

{% block body %}
<div class="post-container">
    
    <div class="back-button-wrapper">
        <a href="{{ path('app_post') }}" class="ui-pill-button">← Retour aux articles</a>
    </div>
    {% for message in app.flashes('success') %}
        <div class="alert alert-success">
            {{ message }}
        </div>
    {% endfor %}
    <article class="ui-display-panel">
        <header>
            <span class="ui-badge">{{ post.category.name }}</span>
            <h1 class="main-title">{{ post.title }}</h1>
            <p class="post-metadata">
                Posté par <strong>Admin</strong> • le {{ post.createdAt|date('d/m/Y') }}
            </p>
        </header>

        <hr class="ui-separator-thick">

       <div class="post-full-content">
            {{ post.content|markdown_to_html|optimize_images}}
        </div>

        <hr class="post-separator">

        <section class="post-interactions">
            {% if app.user %}
                <a href="{{ path('app_post_like', {'id': post.id}) }}"
                    class="ui-pill-like {{ post.isLikeByUser(app.user) ? 'is-active' : '' }}">
                        <span class="like-icon">{{ post.isLikeByUser(app.user) ? '❤️' : '🤍' }}</span>
                        <span class="like-count">{{ post.postLikes|length }}</span>
                        <span class="like-label">{{ post.postLikes|length > 1 ? 'Likes' : 'Like' }}</span>
                </a>
            {% else %}
                <div class="ui-pill-like is-disabled">
                    <span class="like-icon">❤️</span>
                    <span class="like-count">{{ post.postLikes|length }}</span>
                    <span class="like-label">{{ post.postLikes|length > 1 ? 'Likes' : 'Like' }}</span>
                    <a href="{{ path('app_login', { '_target_path': app.request.uri }) }}" class="like-helper">(Connectez-vous pour liker)</a>
                </div>
            {% endif %}
        </section>

        <div class="share-section">
            <p class="share-title">Cet article t'a plu ?</p>
            
            <div class="share-actions">
                <button id="copy-share-link" 
                    class="ui-pill-button active" 
                    data-url="{{ url('app_post_show', {id: post.id}) }}">
                    <span>🔗</span> Copier le lien de l'article
                </button>
                
                <span id="share-success">✓ Lien copié !</span>
            </div>
        </div>
    </article>
    <section class="ui-display-panel">
        <h3 class="">
            <i class="fa-solid fa-comments"></i> 
            {{ post.comments|length }} Commentaire(s)
        </h3>
        {{ form_start(commentForm) }}
        {{ form_row(commentForm.content) }}
        {% if app.user %}
            <button type="submit" class="">Publier</button>
        {% else %}
            <div class="">
                <p>Vous devez être <a href="{{ path('app_login', { '_target_path': app.request.uri }) }}" class="like-helper">connecté</a> pour commenter.</p>
                <button type="button" class="" disabled>Publier (Connexion requise)</button>
            </div>
        {% endif %}
        {{ form_end(commentForm) }}
        <div class="">
            {% for comment in post.comments %}
                <article class="ui-post-card">
                    <header class="">
                        <span class="">{{ comment.user.displayName }}</span>

                        <div class="">
                            {% for badge in comment.user.badges %}
                                <span class="" title="{{ badge.label }}" style="background-color: {{ badge.color }};">
                                    {% if badge.icon %}
                                        <i class="fa-solid {{ badge.icon }}"></i>
                                    {% endif %}
                                    <span class="">{{ badge.label }}</span>
                                </span>
                            {% endfor %}
                        </div>

                        <time class="" datetime="{{ comment.createdAt|date('c') }}">
                            Posté le {{ comment.createdAt|date('d/m/Y à H:i') }}
                        </time>
                    </header>

                    <div class="">
                        {{ comment.content|nl2br }}
                    </div>
                    <hr class="post-separator">
                </article>
            {% else %}
                <p class="">Aucun commentaire pour le moment.</p>
            {% endfor %}
        </div>
    </section>
    <div class="back-button-wrapper">
        <a href="{{ path('app_post') }}" class="ui-pill-button">← Retour aux articles</a>
    </div>
</div>
{% endblock %}
