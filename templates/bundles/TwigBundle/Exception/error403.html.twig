{# templates/bundles/TwigBundle/Exception/error403.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Accès Refusé !{% endblock %}

{% block body %}
<div class="container post-container">
    <div class="main-display-card" style="text-align: center;">
        <h1 class="main-title">Oups ! Zone Interdite 🚧</h1>
        <hr class="kenney-hr">
        
        <p style="font-size: 1.2rem; margin: 20px 0;">
            Désolé, mais tu n'as pas les permissions nécessaires pour accéder à cette page. 
            C'est réservé aux administrateurs !
        </p>

        <div style="margin-top: 30px;">
            <a href="{{ path('app_home') }}" class="pill active">Retour à l'accueil</a>
        </div>
        
        <p style="margin-top: 20px; font-style: italic; opacity: 0.7;">
            (Erreur 403 : Forbidden)
        </p>
    </div>
</div>
{% endblock %}