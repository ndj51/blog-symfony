{# templates/bundles/TwigBundle/Exception/error404.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Page introuvable - 404{% endblock %}

{% block body %}
<div class="container post-container">
    <div class="main-display-card" style="text-align: center;">
        <h1 class="main-title">404 - Perdu dans les pixels ? 🕹️</h1>
        <hr class="kenney-hr">
        
        <p style="font-size: 1.2rem; margin: 20px 0;">
            Désolé, la page que tu cherches n'existe pas ou a été déplacée. 
            (Peut-être qu'elle s'est cachée derrière un buisson !)
        </p>

        <div style="margin-top: 30px;">
            <a href="{{ path('app_home') }}" class="pill active">Retourner à l'accueil</a>
        </div>
        
        <p style="margin-top: 40px; font-size: 0.8rem; opacity: 0.5;">
            Code erreur : 404 Not Found
        </p>
    </div>
</div>
{% endblock %}