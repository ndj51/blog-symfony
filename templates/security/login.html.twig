{# /templates/security/login.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Espace Membre{% endblock %}

{% block body %}
<div class="post-container">
    <div class="ui-display-panel">
        <h1 class="main-title">Espace Membre</h1>
        <hr class="ui-separator-thick">

        <div class="auth-grid">
            
            {# --- COLONNE GAUCHE : CONNEXION --- #}
            <div class="login-section">
                <h2 class="share-title">Déjà inscrit ?</h2>
                
                <form method="post">
                    {% if error %}
                        <div class="alert alert-danger">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
                    {% endif %}

                    <div class="form-group">
                        <label for="username">Email</label>
                        <input type="email" value="{{ last_username }}" name="_username" id="username" class="ui-input" autocomplete="email" required autofocus>
                    </div>
                    
                    <div class="form-group">
                        <label for="password">Mot de passe</label>
                        <input type="password" name="_password" id="password" class="ui-input" autocomplete="current-password" required>
                    </div>

                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
                    <input type="hidden" name="_target_path" value="{{ app.request.query.get('_target_path') }}">

                    <button class="ui-pill-filter active" type="submit">
                        🚀 Se connecter
                    </button>
                </form>
            </div>

            {# Séparation visuelle verticale #}
            <div class="separator-v"></div>

            {# --- COLONNE DROITE : INSCRIPTION --- #}
            <div class="register-section">
                <h2 class="share-title">Nouveau ici ?</h2>
                
                {{ form_start(registrationForm) }}
                    <div class="form-group">
                        {{ form_label(registrationForm.email, 'Votre adresse email') }}
                        {{ form_widget(registrationForm.email, {'attr': {'class': 'ui-input'}}) }}
                    </div>

                    <div class="form-group">
                        {{ form_label(registrationForm.plainPassword, 'Choisir un mot de passe') }}
                        {{ form_widget(registrationForm.plainPassword, {'attr': {'class': 'ui-input'}}) }}
                    </div>

                    <div class="form-check">
                        {{ form_widget(registrationForm.agreeTerms) }}
                        {{ form_label(registrationForm.agreeTerms, "J'accepte les conditions d'utilisation") }}
                        {{ form_errors(registrationForm.agreeTerms) }}
                    </div>
                    
                    <input type="hidden" name="_target_path" value="{{ app.request.query.get('_target_path') }}">

                    <button type="submit" class="ui-pill-filter">
                        ✨ Créer mon compte
                    </button>
                {{ form_end(registrationForm) }}
            </div>
        </div>
    </div>
</div>
{% endblock %}
